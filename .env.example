# Authentication (required)
# The server hashes this token; clients send `Authorization: Ripclone <sha256>`.
RIPCLONE_SERVER_TOKEN=change-me-in-production

# GitHub App credentials (optional — enables private repo sync and webhooks)
# Create a GitHub App at https://github.com/settings/apps/new
RIPCLONE_APP_ID=123456
RIPCLONE_PRIVATE_KEY_PATH=./ripclone.pem
RIPCLONE_WEBHOOK_SECRET=your-webhook-secret

# A classic GitHub token with `repo` scope, used when mirroring private repos.
RIPCLONE_GITHUB_TOKEN=

# GitHub App credential broker (optional). When RIPCLONE_GITHUB_APP_ID is set,
# the server authenticates upstream as a GitHub App installation: it signs a
# short-lived app JWT and exchanges it for an installation access token (cached
# until shortly before it expires) instead of using a static token. Provide the
# private key inline (RIPCLONE_GITHUB_APP_PRIVATE_KEY) or via a file path
# (RIPCLONE_GITHUB_APP_PRIVATE_KEY_PATH). RIPCLONE_GITHUB_API_BASE overrides the
# REST API base for GitHub Enterprise.
# RIPCLONE_GITHUB_APP_ID=123456
# RIPCLONE_GITHUB_APP_INSTALLATION_ID=7891011
# RIPCLONE_GITHUB_APP_PRIVATE_KEY_PATH=./ripclone-app.pem
# RIPCLONE_GITHUB_APP_PRIVATE_KEY=
# RIPCLONE_GITHUB_API_BASE=https://api.github.com

# Server settings
RIPCLONE_HOST=0.0.0.0
RIPCLONE_PORT=8000
RIPCLONE_LOG_LEVEL=info

# Local cache directory. When S3 is configured this is the on-disk cache.
RIPCLONE_CACHE_DIR=./data/cache

# Base URL for upstream git origins (e.g. your GitHub App proxy).
# Default is `https://github.com`.
# RIPCLONE_ORIGIN_BASE=https://github.com

# Ref in-memory cache TTL (seconds)
RIPCLONE_REF_CACHE_TTL_SECS=30

# Rate limiter. Tests override these to avoid throttling.
RIPCLONE_RATE_LIMIT_BURST=60
RIPCLONE_RATE_LIMIT_PER_SEC=10

# ------------------------------------------------------------------------------
# Storage backend
# ------------------------------------------------------------------------------
# Local filesystem is used when S3 is not configured.
# To use Tigris / S3-compatible storage, set these:
RIPCLONE_S3_ENDPOINT=
RIPCLONE_S3_REGION=us-east-1
RIPCLONE_S3_BUCKET=
# Optional prefix for all objects, e.g. "prod/". Must end with `/` if non-empty.
RIPCLONE_S3_PREFIX=
# Comma-separated list of regions shown in the billing status endpoint.
RIPCLONE_STORAGE_REGIONS=us-east-1

# AWS-style credentials for the S3-compatible store.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# ------------------------------------------------------------------------------
# Remote garbage collection
# ------------------------------------------------------------------------------
# Interval between background GC passes. Set to 0 to disable.
RIPCLONE_REMOTE_GC_INTERVAL_SECS=0
# Grace period: objects newer than this are never deleted (seconds).
RIPCLONE_REMOTE_GC_GRACE_SECS=86400
# Set to 1/true to log what would be deleted without actually deleting.
RIPCLONE_REMOTE_GC_DRY_RUN=false

# ------------------------------------------------------------------------------
# Build / sync behaviour
# ------------------------------------------------------------------------------
# Two-phase publish (a fast depth=1 variant is returned immediately while the
# full clonepack builds in the background) and routing builds through the
# bounded background queue are always on now; they have no env toggle.
# LSM-style incremental compaction for history tails.
RIPCLONE_LSM=0
# Seal a new LSM level tail when it grows past this many bytes.
RIPCLONE_LSM_SEAL_BYTES=1048576

# Local cache disabled for the client when set.
# RIPCLONE_NO_CACHE=1
