# GitHub App credentials
# Create a GitHub App at https://github.com/settings/apps/new
REPOLAYER_APP_ID=123456
REPOLAYER_PRIVATE_KEY_PATH=./ripclone.pem
REPOLAYER_WEBHOOK_SECRET=your-webhook-secret

# Server settings
REPOLAYER_HOST=0.0.0.0
REPOLAYER_PORT=8000
REPOLAYER_CACHE_DIR=./data/cache
REPOLAYER_LOG_LEVEL=info

# Staleness budget for cached refs (seconds)
REPOLAYER_DEFAULT_STALENESS=30
